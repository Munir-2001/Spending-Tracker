# Supabase — get these from your Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Only needed locally to run scripts/import-data.ts (NEVER commit / never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Encrypts sensitive text (account names/numbers, institutions, merchants, people, notes)
# before it's stored. Generate with:  openssl rand -base64 32
# IMPORTANT: back this up — lose it and encrypted fields are unrecoverable.
APP_ENCRYPTION_KEY=your-32-byte-base64-key
